<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - SteamCord</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <style>
        body {
            background:
                radial-gradient(circle at top,
                    rgba(88, 101, 242, 0.25),
                    transparent 40%),
                #0f1117;

            min-height: 100vh;
            color: #f1f1f1;
            overflow: hidden;
        }

        .auth-card {
            background: rgba(25, 28, 36, 0.95);

            border: 1px solid rgba(255,255,255,0.08);

            backdrop-filter: blur(10px);

            border-radius: 24px;

            box-shadow:
                0 0 40px rgba(0,0,0,0.35),
                0 0 80px rgba(88, 101, 242, 0.10);
        }

        .steam-avatar {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            border: 3px solid rgba(255,255,255,0.08);
            object-fit: cover;
        }

        .status-icon {
            font-size: 5rem;
            line-height: 1;
        }

        .muted-text {
            color: rgba(255,255,255,0.6);
        }
    </style>
</head>

<body>

    <main class="container vh-100 d-flex justify-content-center align-items-center">
        @RenderBody()
    </main>

</body>
</html>